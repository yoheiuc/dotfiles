{
  "mcpServers": {
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    },
    "vision": {
      "command": "npx",
      "args": [
        "-y",
        "@tuannvm/vision-mcp-server"
      ]
    },
    "serena": {
      "command": "bash",
      "args": [
        "-lc",
        "\"$HOME/.local/bin/serena-mcp\" claude-code"
      ],
      "env": {
        "UV_NATIVE_TLS": "true"
      }
    }
  }
}
