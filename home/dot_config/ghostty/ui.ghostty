# ui.ghostty — fonts, colours, window chrome

font-family = "JetBrainsMono Nerd Font"
font-size    = 14

# Catppuccin Mocha (bundled theme name in Ghostty)
theme = Catppuccin Mocha

# Window
window-padding-x     = 8
window-padding-y     = 6
macos-titlebar-style = tabs
macos-option-as-alt = true

# Cursor
cursor-style       = block
cursor-style-blink = true
