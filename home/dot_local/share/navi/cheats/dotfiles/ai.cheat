% aider, ai

# Aider を起動
aider

# 特定のファイルを追加して Aider を起動
aider <file1> <file2>

# OpenAI 互換 API キーで Aider を起動
OPENAI_API_KEY=<key> aider

# Aider のバージョンを確認
aider --version

% claude, ai

# Claude Code を起動 (対話モード)
claude

# Claude に質問を投げる
claude "<prompt>"

# Claude Code の状態を確認
claude status

# MCP サーバーの状態を確認
claude mcp list

# Claude Code の設定を管理
claude config <key> <value>

# Claude Code のアップデート
claude update

# 特定のディレクトリをコンテキストとして Claude を起動
claude -C <directory>
