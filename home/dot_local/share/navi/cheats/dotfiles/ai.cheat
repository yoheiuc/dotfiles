% gemini, ai

# Gemini CLI を起動
gemini

# Gemini に質問を投げる
gemini "<prompt>"

# 特定のファイルを読み込ませて質問
gemini --file <file> "<prompt>"

# モデルや温度パラメータを指定して実行
gemini --model <model_id> --temperature <temp> "<prompt>"

# Gemini CLI のバージョンを確認
gemini --version

# Gemini CLI の設定を表示
gemini config

% claude, ai

# Claude Code を起動 (対話モード)
claude

# Claude に質問を投げる
claude "<prompt>"

# Claude Code の状態を確認
claude status

# MCP サーバーの状態を確認
claude mcp list

# Claude Code の設定を管理
claude config <key> <value>

# Claude Code のアップデート
claude update

# 特定のディレクトリをコンテキストとして Claude を起動
claude -C <directory>
