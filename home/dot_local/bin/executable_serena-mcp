#!/bin/bash

set -euo pipefail

context="${1:-}"
if [[ -z "${context}" ]]; then
  printf 'usage: %s <context>\n' "$0" >&2
  exit 64
fi

export HOME="${HOME}"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
SERENA_UVX_BIN="${SERENA_UVX_BIN:-/opt/homebrew/bin/uvx}"

project_dir="$(pwd)"
is_git_repo=0
if git -C "${project_dir}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  project_dir="$(git -C "${project_dir}" rev-parse --show-toplevel)"
  is_git_repo=1
fi

if [[ "${SERENA_AUTO_INDEX:-1}" != "0" ]] && [[ "${is_git_repo}" == "1" ]]; then
  "${SERENA_UVX_BIN}" \
    -q \
    --from git+https://github.com/oraios/serena \
    serena index-project "${project_dir}" >/dev/null 2>&1 || true
fi

exec "${SERENA_UVX_BIN}" \
  -q \
  --from git+https://github.com/oraios/serena \
  serena start-mcp-server \
  --context="${context}" \
  --project-from-cwd \
  --open-web-dashboard False
