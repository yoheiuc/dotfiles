# ui.ghostty — fonts, colours, window chrome

font-family = "JetBrains Mono"
font-size    = 14

# Catppuccin Mocha (bundled theme name in Ghostty)
theme = Catppuccin Mocha

# Window
window-padding-x     = 8
window-padding-y     = 6
macos-titlebar-style = hidden

# Cursor
cursor-style       = block
cursor-style-blink = true
