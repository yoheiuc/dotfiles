# ~/.Brewfile — managed by chezmoi (source: home/dot_Brewfile)
# Initial install:  brew bundle --file=<repo>/home/dot_Brewfile
# After apply:      brew bundle --global
# Verify:           brew bundle check --global

# ---------- Taps ----------
tap "homebrew/bundle"

# ---------- CLI tools ----------
brew "chezmoi"    # dotfiles manager
brew "git"
brew "gh"         # GitHub CLI
brew "jq"         # JSON processor
brew "yq"         # YAML/JSON/TOML processor
brew "ripgrep"    # fast grep (rg)
brew "fd"         # fast find
brew "fzf"        # fuzzy finder
brew "bat"        # cat with syntax highlighting
brew "eza"        # modern ls
brew "starship"   # cross-shell prompt
brew "direnv"     # per-directory env vars
brew "uv"         # fast Python package manager
brew "shellcheck" # shell script linter (used in CI)

# ---------- Casks ----------
cask "ghostty"      # GPU-accelerated terminal
cask "claude"       # Claude desktop (includes claude CLI)
