#!/bin/bash

set -euo pipefail

resolve_dotfiles_root() {
  if [[ -n "${DOTFILES_REPO_ROOT:-}" && -d "${DOTFILES_REPO_ROOT}" ]]; then
    printf '%s\n' "${DOTFILES_REPO_ROOT}"
    return 0
  fi

  if command -v chezmoi >/dev/null 2>&1; then
    local source_path repo_root
    source_path="$(chezmoi source-path "${HOME}/.local/bin/ai-secrets" 2>/dev/null || true)"
    if [[ -n "${source_path}" && -f "${source_path}" ]]; then
      repo_root="$(cd "$(dirname "${source_path}")/../../../.." && pwd)"
      if [[ -d "${repo_root}/scripts" ]]; then
        printf '%s\n' "${repo_root}"
        return 0
      fi
    fi
  fi

  if [[ -d "${HOME}/.local/share/chezmoi" ]]; then
    printf '%s\n' "${HOME}/.local/share/chezmoi"
    return 0
  fi

  if [[ -d "${HOME}/dotfiles" ]]; then
    printf '%s\n' "${HOME}/dotfiles"
    return 0
  fi

  return 1
}

DOTFILES_ROOT="$(resolve_dotfiles_root)" || {
  printf 'ai-secrets: could not locate the dotfiles repo\n' >&2
  exit 1
}

exec bash "${DOTFILES_ROOT}/scripts/ai-secrets.sh" "$@"
