#!/bin/bash

set -euo pipefail

SECURITY_BIN="${SECURITY_BIN:-security}"
AI_SHARED_ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/ai-secrets.env"
AI_SHARED_ENV_FALLBACK_FILE="${HOME}/.config/dotfiles/ai-secrets.env"

usage() {
  printf 'usage: %s <env_name> <service> <account> <command> [args...]\n' "$0" >&2
  exit 64
}

if [[ "$#" -lt 4 ]]; then
  usage
fi

env_name="$1"
service="$2"
account="$3"
shift 3

secret=""
if command -v "${SECURITY_BIN}" >/dev/null 2>&1; then
  secret="$("${SECURITY_BIN}" find-generic-password -w -s "${service}" -a "${account}" 2>/dev/null || true)"
fi

if [[ -z "${secret}" ]]; then
  env_file="${AI_SHARED_ENV_FILE}"
  if [[ ! -f "${env_file}" && "${AI_SHARED_ENV_FALLBACK_FILE}" != "${env_file}" && -f "${AI_SHARED_ENV_FALLBACK_FILE}" ]]; then
    env_file="${AI_SHARED_ENV_FALLBACK_FILE}"
  fi

  if [[ -f "${env_file}" ]]; then
    # shellcheck disable=SC1090
    secret="$(
      env -i bash -lc "
        set -a
        source '${env_file}'
        set +a
        printf '%s' \"\${${env_name}:-}\"
      " 2>/dev/null
    )"
  fi
fi

if [[ -z "${secret}" ]]; then
  printf '%s: missing secret for %s (%s/%s)\n' "$0" "${env_name}" "${service}" "${account}" >&2
  exit 1
fi

export "${env_name}=${secret}"
exec "$@"
