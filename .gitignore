# Claude Code local session permissions (machine-specific, not for tracking)
.claude/settings.local.json

# Claude Code project-local skills (installed by `playwright-cli install --skills`
# when invoked outside $HOME). Dotfiles doesn't track project-local skills.
.claude/skills/

# Claude Code scheduled tasks runtime lock (machine-local; created by /schedule).
.claude/scheduled_tasks.lock

# Leftover state from the retired Serena MCP (see issue #60 / 2026-04-24).
# Ignored so old project-local .serena/ directories don't surface in `git status`.
# Safe to delete manually; nothing in the repo depends on it any more.
.serena/

# Playwright CLI local state (machine-specific, not for tracking)
.playwright-cli/

# chezmoi local data overrides (machine-specific)
.chezmoidata.yaml

# Python bytecode
__pycache__/
*.pyc

# macOS
.DS_Store
**/.DS_Store

# Ghostty local overrides (machine-specific)
home/dot_config/ghostty/local.ghostty

# Editor swap / project metadata
*.swp
*.swo
.idea/
.vscode/

# direnv cache (if used per-dir)
.direnv/

# Dotenv files (should never be committed; defense in depth)
.env
.env.*
!.env.example

# Node artifacts (not expected in this repo, but defensive)
node_modules/
