{
  "mcpServers": {
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "brave-search": {
      "command": "bash",
      "args": [
        "-lc",
        "\"$HOME/.local/bin/mcp-with-keychain-secret\" BRAVE_API_KEY dotfiles.ai.mcp brave-api-key npx -y @modelcontextprotocol/server-brave-search"
      ]
    },
    "serena": {
      "command": "bash",
      "args": [
        "-lc",
        "\"$HOME/.local/bin/serena-mcp\" claude-code"
      ],
      "env": {
        "UV_NATIVE_TLS": "true"
      }
    }
  }
}
